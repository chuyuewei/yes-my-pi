{
  "$schema": "yes-my-pi settings (read by ext-permissions)",
  "version": 1,

  "approval": {
    "defaultMode": "auto-edit",
    "modes": {
      "suggest": "Every tool call requires user confirmation",
      "auto-edit": "Read-only tools auto-approved, writes require confirmation",
      "full-auto": "Everything auto-approved (deny rules still apply)",
      "always-yes": "Everything auto-approved, including deny rules. Session-only. Requires confirmation to activate."
    },
    "dangerousModes": ["always-yes"],
    "askTimeoutMs": 60000
  },

  "permissions": {
    "rulesFile": "permissions.default.yaml",
    "globalRulesPath": "~/.pi/agent/permissions.yaml",
    "projectRulesPath": ".pi/permissions.yaml",
    "sessionOverrides": true,
    "watcher": {
      "enabled": true,
      "debounceMs": 150,
      "pollIntervalMs": 1000
    }
  },

  "ui": {
    "statusKey": "ymp-mode",
    "maxArgsDisplay": 200
  },

  "identity": {
    "name": "yes-my-pi",
    "alias": "ymp",
    "systemPromptFile": "SYSTEM.md",
    "agentsTemplateFile": "AGENTS.md"
  }
}
